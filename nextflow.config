params {
    mode              = 'timepoint_build'
    output_root       = "${projectDir}"
    publish_root      = "${projectDir}/data/releases"
    timepoint_id      = null
    timepoint_root    = null
    t0_id             = null
    t1_id             = null
    t0_root           = null
    t1_root           = null
    release_id        = null
    release_root      = null
    method_names_file = null
    split_size        = 64
    prediction_target_mode = 'window_groundtruth'
    window_prediction_subdir = 'predictions_by_window'
    window_prediction_mode = 'generate'
    window_predictions_dir = null
    funbind_batch_size = 20
    enabled_window_methods = [
        'naive',
        'goa_nonexp',
        'blast',
        'prott5',
        'transfew',
        'funbind',
        'deepgoplus'
    ]
    workspace_root    = "${projectDir}"
    democafa_package  = "/work/idoerg/ahphan/democafa_package"
    democafa_env      = "democafaenv"
    cafaeval_env      = "cafa5-evaluator"
}

process {
    executor = 'local'
    shell = ['/bin/bash', '-euo', 'pipefail']

    withName: 'EVALUATE_WINDOW:PREDICT_NAIVE' {
        errorStrategy = 'ignore'
    }

    withName: 'EVALUATE_WINDOW:PREDICT_GOA_NONEXP' {
        errorStrategy = 'ignore'
    }

    withName: 'EVALUATE_WINDOW:PREDICT_BLAST' {
        errorStrategy = 'ignore'
    }

    withName: 'EVALUATE_WINDOW:PREDICT_PROTT5' {
        errorStrategy = 'ignore'
    }

    withName: 'EVALUATE_WINDOW:PREDICT_TRANSFEW' {
        errorStrategy = 'ignore'
    }

    withName: 'EVALUATE_WINDOW:PREDICT_FUNBIND_BATCH' {
        errorStrategy = 'retry'
        maxRetries = 2
    }

    withName: 'EVALUATE_WINDOW:PREDICT_DEEPGOPLUS' {
        errorStrategy = 'retry'
        maxRetries = 3
    }

    withLabel: 'cpu_small' {
        cpus = 4
        memory = '16 GB'
        time = '6h'
    }

    withLabel: 'cpu_medium' {
        cpus = 16
        memory = '64 GB'
        time = '12h'
    }

    withLabel: 'cpu_large' {
        cpus = 16
        memory = '128 GB'
        time = '24h'
    }

    withLabel: 'gpu_a100' {
        cpus = 16
        memory = '256 GB'
        time = '36h'
    }

    withLabel: 'packaging' {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }
}

profiles {
    local {
        process {
            executor = 'local'
        }
    }

    slurm {
        apptainer.enabled = true

        process {
            executor = 'slurm'
            queue = null

            withLabel: 'cpu_small' {
                cpus = 4
                memory = '16 GB'
                time = '2h'
            }

            withLabel: 'cpu_medium' {
                cpus = 16
                memory = '64 GB'
                time = '12h'
            }

            withLabel: 'cpu_large' {
                cpus = 16
                memory = '128 GB'
                time = '24h'
            }

            withLabel: 'gpu_a100' {
                cpus = 16
                memory = '256 GB'
                time = '36h'
                clusterOptions = '--gres=gpu:a100:1'
            }

            withLabel: 'gpu_scavenger' {
                cpus = 16
                memory = '256 GB'
                time = '2h'
                clusterOptions = '--partition=scavenger --gres=gpu:a100:1'
            }

            withLabel: 'packaging' {
                cpus = 2
                memory = '8 GB'
                time = '2h'
            }
        }
    }
}
